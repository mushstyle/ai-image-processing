{
  "name": "nano-banana",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Private Nano Banana workshop playground",
  "scripts": {
    "dev": "concurrently -k -n client,server -c magenta,cyan \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite --host 127.0.0.1 --port 5173",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "NODE_ENV=production node dist/server/index.js",
    "lint": "eslint .",
    "deploy": "bash ./scripts/deploy.sh",
    "server:start": "bash ./scripts/server-start.sh",
    "server:stop": "bash ./scripts/server-stop.sh",
    "server:restart": "bash ./scripts/server-restart.sh"
  },
  "engines": {
    "node": ">=22.10.0"
  },
  "dependencies": {
    "@clerk/express": "^2.0.4",
    "@clerk/react": "^6.1.0",
    "@google/genai": "^1.16.0",
    "@tailwindcss/vite": "^4.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "multer": "^2.0.2",
    "react": "^19.1.4",
    "react-dom": "^19.1.4",
    "sharp": "^0.34.3",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "typescript-eslint": "^8.57.0"
  }
}
